# ─────────────────────────────────────────
# RAG Chatbot Environment Variables
# Copy this file to .env and fill in YOUR values
# NEVER commit .env to GitHub!
# ─────────────────────────────────────────

# Path to your local LLaMA model (.gguf file)
MODEL_PATH=models/your-model-name.gguf

# ChromaDB storage path
CHROMA_DB_PATH=./chroma_db

# ChromaDB collection name
COLLECTION_NAME=pdf_docs

# Server settings
HOST=0.0.0.0
PORT=8000

# LLaMA settings (tune based on your hardware)
N_CTX=2560
N_THREADS=4
N_BATCH=512
N_GPU_LAYERS=0
MAX_NEW_TOKENS=300

# Max upload size for PDFs (in MB)
MAX_UPLOAD_MB=20
